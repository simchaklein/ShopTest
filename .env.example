# ShopTest storage
BLOB_READ_WRITE_TOKEN=
SHOPTEST_DB_PREFIX=shoptest-db

# Optional Basic Auth for protected environments
SHOPTEST_BASIC_AUTH_USERNAME=
SHOPTEST_BASIC_AUTH_PASSWORD=
SHOPTEST_DISABLE_BASIC_AUTH=false

# Max Pay / Hyp feature flags
MAXPAY_ENV=test
MAXPAY_ENABLE_CORE_CHECKOUT=true
MAXPAY_ENABLE_RECURRING=false
MAXPAY_ENABLE_INVOICES=false
MAXPAY_ENABLE_APPLE_PAY=false
MAXPAY_ENABLE_GOOGLE_PAY=false
MAXPAY_ENABLE_DIAGNOSTICS=true

# Max Pay / Hyp credentials - set values only in local/Vercel env, never commit real values
HYP_TERMINAL=YOUR_HYP_TEST_TERMINAL
HYP_USER=YOUR_HYP_TEST_USER
HYP_PASSWORD=YOUR_HYP_TEST_PASSWORD
HYP_MID=YOUR_HYP_TEST_MID_IF_REQUIRED
HYP_ENDPOINT=https://pay.hyp.co.il/cgi-bin/yaadpay/yaadpay.pl

# Public deployed URL used for Hyp redirects/callbacks
MAXPAY_PUBLIC_BASE_URL=https://your-shoptest-preview.vercel.app
MAXPAY_SUCCESS_URL=https://your-shoptest-preview.vercel.app/payment/success
MAXPAY_FAILED_URL=https://your-shoptest-preview.vercel.app/payment/failed
MAXPAY_CANCEL_URL=https://your-shoptest-preview.vercel.app/payment/cancel
MAXPAY_NOTIFY_URL=https://your-shoptest-preview.vercel.app/api/max-pay/notify
