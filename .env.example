# ShopTest storage
BLOB_READ_WRITE_TOKEN=
SHOPTEST_DB_PREFIX=shoptest-db

# Optional Basic Auth for protected environments
SHOPTEST_BASIC_AUTH_USERNAME=
SHOPTEST_BASIC_AUTH_PASSWORD=
SHOPTEST_DISABLE_BASIC_AUTH=false

# Max Pay / Hyp minimum required for hosted TEST checkout
HYP_PAYMENT_PAGE_URL=YOUR_HYP_PAYMENT_PAGE_URL
HYP_TERMINAL=YOUR_HYP_TERMINAL

# Optional: only if Hyp explicitly requires them for your terminal
# HYP_API_KEY=YOUR_HYP_API_KEY
# HYP_PASSP=YOUR_HYP_PASSP
# HYP_MID=YOUR_HYP_MID

# Optional overrides. Defaults live in lib/maxpay/config.ts
# MAXPAY_PUBLIC_BASE_URL=https://your-shoptest-domain.vercel.app
# MAXPAY_ENV=test
# MAXPAY_PROVIDER_MODE=yaadpay_hosted
